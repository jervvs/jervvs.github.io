---
import { getCollection, getEntry, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

// Map collection names to URL prefixes
const urlPrefixes: Record<string, string> = {
  posts: 'writing',
  projects: 'projects',
  building: 'building',
};

export async function getStaticPaths() {
  const items = await getCollection('building');
  return items.map(item => ({
    params: { slug: item.id },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await render(item);

// Resolve related work refs → { title, url, date? }
const resolvedWork = await Promise.all(
  item.data.relatedWork.map(async (ref: string) => {
    const [collection, id] = ref.split('/');
    const entry = await getEntry(collection as any, id);
    if (!entry) return null;
    const urlPrefix = urlPrefixes[collection] || collection;
    return {
      title: entry.data.title,
      url: `/${urlPrefix}/${id}/`,
      date: (entry.data as any).date as Date | undefined,
    };
  })
);

const timeline = resolvedWork
  .filter((w): w is NonNullable<typeof w> => w !== null)
  .sort((a, b) => {
    if (a.date && b.date) return b.date.valueOf() - a.date.valueOf();
    if (a.date) return -1;
    return 1;
  });
---

<BaseLayout title={item.data.title} description={item.data.description}>
  <a href="/building/" class="back-link">← Back to building</a>

  <article class="building-page">
    <h1 class="building-title">{item.data.title}</h1>
    <p class="building-desc">{item.data.description}</p>

    {item.data.tags.length > 0 && (
      <div class="building-tags">
        {item.data.tags.map(tag => <span class="building-tag">{tag}</span>)}
      </div>
    )}

    <div class="building-body">
      <Content />
    </div>

    {timeline.length > 0 && (
      <div class="related-work">
        <div class="section-label">Timeline</div>
        <div class="timeline">
          {timeline.map((work, i) => (
            <a href={work.url} class="timeline-item">
              <span class="timeline-date">
                {work.date ? new Intl.DateTimeFormat('en-US', { month: 'short', year: 'numeric' }).format(work.date) : ''}
              </span>
              <span class="timeline-dot-wrapper">
                <span class="timeline-dot"></span>
                {i < timeline.length - 1 && <span class="timeline-line"></span>}
              </span>
              <span class="timeline-title">{work.title}</span>
            </a>
          ))}
        </div>
      </div>
    )}

    {item.data.url && item.data.url !== '#' && (
      <div class="building-link-section">
        <a href={item.data.url} class="building-link" target="_blank" rel="noopener noreferrer">
          Learn more ↗
        </a>
      </div>
    )}

    <footer class="building-footer">
      <a href="/building/" class="back-link" style="margin-bottom: 0;">← All building</a>
    </footer>
  </article>
</BaseLayout>

<style>
  .building-title {
    font-size: 28px;
    font-weight: 200;
    letter-spacing: -0.03em;
    margin-bottom: 10px;
  }

  .building-desc {
    font-size: 15px;
    font-weight: 300;
    color: var(--text-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
  }

  .building-tags {
    display: flex;
    gap: 6px;
    margin-bottom: 36px;
    flex-wrap: wrap;
  }

  .building-tag {
    font-size: 10px;
    font-weight: 300;
    color: var(--text-muted);
    padding: 2px 8px;
    border: 1px solid var(--border);
    border-radius: 10px;
  }

  .building-body {
    max-width: 660px;
  }

  .building-body :global(p) {
    font-size: 15px;
    font-weight: 300;
    line-height: 1.85;
    color: var(--text-secondary);
    margin-bottom: 24px;
  }

  .building-body :global(h2) {
    font-size: 22px;
    font-weight: 300;
    letter-spacing: -0.02em;
    color: var(--text);
    margin-top: 48px;
    margin-bottom: 18px;
  }

  .building-body :global(strong) { font-weight: 500; color: var(--text); }

  .building-body :global(a) {
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: text-decoration-color 0.3s;
  }

  .building-body :global(a:hover) { text-decoration-color: var(--accent); }

  .building-body :global(ul) { margin: 20px 0; padding-left: 24px; list-style: revert; }

  .building-body :global(li) {
    font-size: 15px; font-weight: 300; line-height: 1.8;
    color: var(--text-secondary); margin-bottom: 8px;
  }

  .related-work {
    margin-top: 40px;
    padding-top: 28px;
    border-top: 1px solid var(--border);
  }

  .related-work .section-label {
    margin-bottom: 20px;
  }

  .timeline {
    display: flex;
    flex-direction: column;
  }

  .timeline-item {
    display: grid;
    grid-template-columns: 72px 20px 1fr;
    gap: 0 12px;
    align-items: start;
    text-decoration: none;
    color: inherit;
    padding: 2px 0;
    transition: transform 0.2s;
  }

  .timeline-item:hover {
    transform: translateX(4px);
  }

  .timeline-date {
    font-size: 11px;
    font-weight: 300;
    color: var(--text-muted);
    text-align: right;
    padding-top: 2px;
    transition: color 0.3s;
  }

  .timeline-dot-wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 5px;
  }

  .timeline-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--accent);
    flex-shrink: 0;
  }

  .timeline-line {
    width: 1px;
    height: 32px;
    background: var(--border);
    margin-top: 4px;
    transition: background 0.3s;
  }

  .timeline-title {
    font-size: 14px;
    font-weight: 400;
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--border);
    transition: text-decoration-color 0.3s, color 0.3s;
    padding-bottom: 20px;
  }

  .timeline-item:hover .timeline-title {
    text-decoration-color: var(--accent);
  }

  .timeline-item:last-child .timeline-title {
    padding-bottom: 0;
  }

  .building-link-section {
    margin-top: 36px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }

  .building-link {
    font-size: 14px;
    font-weight: 400;
    color: var(--text);
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: var(--accent);
    transition: color 0.3s;
  }

  .building-footer {
    margin-top: 48px;
    padding-top: 24px;
    border-top: 1px solid var(--border);
  }
</style>
